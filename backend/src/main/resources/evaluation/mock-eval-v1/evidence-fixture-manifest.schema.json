{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:service-insight:evaluation:mock-eval-v1:evidence-manifest",
  "title": "mock-eval-v1 Evidence fixture manifest Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifestVersion", "datasetVersion", "mockData", "executionIdentities", "evidenceFixtures"],
  "properties": {
    "manifestVersion": {"const": "mock-evidence-v1"},
    "datasetVersion": {"const": "mock-eval-v1"},
    "mockData": {"const": true},
    "executionIdentities": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identity"}},
    "evidenceFixtures": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}}
  },
  "$defs": {
    "identity": {
      "type": "object", "additionalProperties": false,
      "required": ["identityCode", "roles", "productLineCodes", "mockData"],
      "properties": {
        "identityCode": {"type": "string", "pattern": "^mock-"},
        "roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "productLineCodes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["TDH", "STREAMING"]}},
        "mockData": {"const": true}
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidenceId", "productLineCode", "language", "document", "versionId", "chunkId", "excerpt", "contentHash", "mockData"],
      "properties": {
        "evidenceId": {"$ref": "#/$defs/mockUuid"},
        "productLineCode": {"enum": ["TDH", "STREAMING"]},
        "language": {"enum": ["ZH", "EN", "MIXED"]},
        "document": {"$ref": "#/$defs/document"},
        "versionId": {"$ref": "#/$defs/mockUuid"},
        "chunkId": {"$ref": "#/$defs/mockUuid"},
        "excerpt": {"type": "string", "pattern": "^模拟数据："},
        "contentHash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "mockData": {"const": true}
      }
    },
    "document": {
      "type": "object", "additionalProperties": false,
      "required": ["documentId", "title"],
      "properties": {
        "documentId": {"$ref": "#/$defs/mockUuid"},
        "title": {"type": "string", "pattern": "^模拟数据："}
      }
    },
    "mockUuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[1-4]0000000-0000-4000-8000-[0-9]{12}$"
    }
  }
}
