{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:service-insight:evaluation:mock-eval-v1:dataset",
  "title": "mock-eval-v1 固定模拟评估集 Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["datasetVersion", "owner", "mockData", "cases"],
  "properties": {
    "datasetVersion": {"const": "mock-eval-v1"},
    "owner": {"type": "string", "minLength": 1},
    "mockData": {"const": true},
    "cases": {"type": "array", "minItems": 30, "items": {"$ref": "#/$defs/case"}}
  },
  "$defs": {
    "nonEmptyUniqueStrings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "uniqueStrings": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runSequence", "contextSnapshot"],
      "properties": {
        "runSequence": {"type": "integer", "minimum": 1, "maximum": 3},
        "contextSnapshot": {"$ref": "#/$defs/precheckInput"}
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseId", "datasetVersion", "languageTags", "scenarioTags", "turns", "executionIdentityCode", "allowedProductLineCodes", "expectedEvidenceIds", "forbiddenEvidenceIds", "expectedRetrievalMode", "expectedDegradation", "expectedMissingFieldCodes", "mockData"],
      "properties": {
        "caseId": {"type": "string", "pattern": "^mock-eval-v1-[0-9]{3}$"},
        "datasetVersion": {"const": "mock-eval-v1"},
        "languageTags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["LANG_ZH", "LANG_EN", "LANG_MIXED"]}},
        "scenarioTags": {"$ref": "#/$defs/nonEmptyUniqueStrings"},
        "turns": {"type": "array", "minItems": 1, "maxItems": 3, "items": {"$ref": "#/$defs/turn"}},
        "executionIdentityCode": {"type": "string", "minLength": 1},
        "allowedProductLineCodes": {"$ref": "#/$defs/nonEmptyUniqueStrings"},
        "expectedEvidenceIds": {"$ref": "#/$defs/uniqueStrings"},
        "forbiddenEvidenceIds": {"$ref": "#/$defs/uniqueStrings"},
        "expectedRetrievalMode": {"enum": ["HYBRID", "FTS_ONLY", "NONE"]},
        "expectedDegradation": {"enum": ["NONE", "FTS_ONLY", "UNAVAILABLE"]},
        "expectedMissingFieldCodes": {"$ref": "#/$defs/uniqueStrings"},
        "mockData": {"const": true}
      }
    },
    "precheckInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceSystem", "hostRequestId", "formSchemaVersion", "issueType", "productLineCode", "productCode", "componentCode", "version", "severity", "serviceType", "title", "descriptionPlainText", "additionalInformation", "impactScope", "attachments"],
      "properties": {
        "sourceSystem": {"const": "MOCK_AIOPS"},
        "hostRequestId": {"type": "string", "pattern": "^mock-host-request-[0-9]{3}$"},
        "formSchemaVersion": {"const": "mock-precheck-form-v1"},
        "issueType": {"enum": ["FUNCTIONAL_FAILURE", "PERFORMANCE_DEGRADATION", "INSTALLATION_CONFIGURATION", "DATA_CORRECTNESS"]},
        "productLineCode": {"enum": ["TDH", "STREAMING"]},
        "productCode": {"type": "string", "minLength": 1},
        "componentCode": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "severity": {"enum": ["P1", "P2", "P3", "P4"]},
        "serviceType": {"type": "string", "minLength": 1},
        "title": {"type": "string", "pattern": "^模拟数据："},
        "descriptionPlainText": {"type": "string", "pattern": "^模拟数据："},
        "additionalInformation": {"type": "array", "items": {"$ref": "#/$defs/additionalInformation"}},
        "impactScope": {"type": "string", "pattern": "^模拟数据："},
        "attachments": {"type": "array", "items": {"$ref": "#/$defs/attachment"}}
      }
    },
    "additionalInformation": {
      "type": "object", "additionalProperties": false,
      "required": ["fieldCode", "displayName", "value"],
      "properties": {
        "fieldCode": {"type": "string", "minLength": 1},
        "displayName": {"type": "string", "minLength": 1},
        "value": {"type": "string", "pattern": "^模拟数据："}
      }
    },
    "attachment": {
      "type": "object", "additionalProperties": false,
      "required": ["attachmentId", "fileName", "mediaType", "sizeBytes"],
      "properties": {
        "attachmentId": {"type": "string", "pattern": "^mock-attachment-"},
        "fileName": {"type": "string", "pattern": "^模拟数据-"},
        "mediaType": {"type": "string", "minLength": 1},
        "sizeBytes": {"type": "integer", "minimum": 0}
      }
    }
  }
}
