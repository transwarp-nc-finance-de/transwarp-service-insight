{
  "name": "service-insight-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "openapi:v1:check": "swagger-cli validate ../docs/api/openapi.yaml",
    "openapi:v2:check": "swagger-cli validate ../docs/api/openapi-v2.yaml",
    "openapi:check": "npm run openapi:v1:check && npm run openapi:v2:check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test e2e/fts-degradation.spec.ts e2e/v1-regression.spec.ts",
    "test:e2e:v1": "playwright test e2e/v1-regression.spec.ts",
    "test:e2e:full": "playwright test e2e/full-vertical-closure.spec.ts",
    "test:e2e:runtime-fault": "playwright test e2e/runtime-degradation.spec.ts --grep @runtime-fault",
    "test:e2e:recovery": "playwright test e2e/runtime-degradation.spec.ts --grep @recovery"
  },
  "dependencies": {
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "4.0.4",
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.30.1",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.36.0",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.12"
  }
}
